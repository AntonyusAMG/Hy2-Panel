# Шаблон переменных окружения (копировать в .env для локальной разработки агента).
# Секреты не коммитить.

# URL мастер-панели (HTTPS)
MASTER_URL=https://master.example.com

# Токен Bearer для API агента (минимум 32 символа; на ноде хранится в config.json)
AGENT_TOKEN=

# Имя ноды (отображается в панели)
NODE_NAME=FI-01 Helsinki

# Домен для TLS (ACME) на ноде Hysteria 2
HY2_DOMAIN=fin.example.com

# Порт HTTP API агента
AGENT_PORT=4000

# Путь к hysteria config (на ноде по умолчанию)
HYSTERIA_CONFIG=/etc/hysteria/config.yaml
